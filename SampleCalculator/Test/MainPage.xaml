<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Test.MainPage"
             Title="Sample Calculator">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,40"
            Spacing="20"
            VerticalOptions="Center">

            <!-- First Number Entry -->
            <Grid ColumnDefinitions="*,*,*,*">
                <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#FAFAFA" Padding="15,10">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Label Text="First Number :" 
                   FontSize="14" 
                   TextColor="#212121" 
                   Grid.Column="0" 
                   VerticalOptions="Center"
                   HorizontalOptions="Center"
                   />
                </Border>
            <Entry
                x:Name="FirstNumberEntry"
                Placeholder="Enter first number"
                Keyboard="Numeric"
                BackgroundColor="#F5F5F5"
                TextColor="#212121"
                PlaceholderColor="#AAAAAA"
                FontSize="16"
                HeightRequest="50"
                Grid.Column="1"/>

            <!-- Second Number Entry -->
                <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#FAFAFA" Padding="15,10" Grid.Column="2">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="8" />
                    </Border.StrokeShape>
                    <Label Text="Second Number :" 
                           FontSize="14" 
                           TextColor="#212121" 
                            
                           VerticalOptions="Center"
                           HorizontalOptions="Center"
                           />
                </Border>
                <Entry
                x:Name="SecondNumberEntry"
                Placeholder="Enter second number"
                Keyboard="Numeric"
                BackgroundColor="#F5F5F5"
                TextColor="#212121"
                PlaceholderColor="#AAAAAA"
                FontSize="16"
                HeightRequest="50" 
                Grid.Column="3"/>
            </Grid>

            <!-- Operation Selection -->
            <Label Text="Select Operation" FontSize="14" TextColor="#555555" Margin="0,10,0,0" />

            <Border Stroke="#E0E0E0" StrokeThickness="1" BackgroundColor="#FAFAFA" Padding="15,10">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <HorizontalStackLayout Spacing="10">
                    <RadioButton
                        x:Name="AddRadio"
                        Content="Add  ( + )"
                        GroupName="Operation"
                        IsChecked="True"
                        TextColor="#212121"
                        FontSize="15" />
                    <RadioButton
                        x:Name="SubtractRadio"
                        Content="Subtract  ( - )"
                        GroupName="Operation"
                        TextColor="#212121"
                        FontSize="15" />
                    <RadioButton
                        x:Name="MultiplyRadio"
                        Content="Multiply  ( × )"
                        GroupName="Operation"
                        TextColor="#212121"
                        FontSize="15" />
                    <RadioButton
                        x:Name="DivideRadio"
                        Content="Divide  ( ÷ )"
                        GroupName="Operation"
                        TextColor="#212121"
                        FontSize="15" />
                </HorizontalStackLayout>
            </Border>

            <!-- Calculate Button -->
            <Button
                x:Name="CalculateBtn"
                Text="Calculate"
                Clicked="OnCalculateClicked"
                BackgroundColor="#1976D2"
                TextColor="White"
                FontSize="16"
                FontAttributes="Bold"
                CornerRadius="8"
                HeightRequest="50"
                Margin="0,10,0,0" />

            <!-- Result Entry -->
            <Label Text="Result" FontSize="14" TextColor="#555555" Margin="0,10,0,0" />
            <Entry
                x:Name="ResultEntry"
                Placeholder="Result will appear here"
                IsReadOnly="True"
                BackgroundColor="#E3F2FD"
                TextColor="#1565C0"
                PlaceholderColor="#90A4AE"
                FontSize="18"
                FontAttributes="Bold"
                HeightRequest="55" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
