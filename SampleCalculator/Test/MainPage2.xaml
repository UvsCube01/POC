<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Test.MainPage2"
             Title="Popup Page"
             Shell.NavBarIsVisible="True"
             Shell.TabBarIsVisible="False">

    <VerticalStackLayout
        Padding="30,40"
        Spacing="25"
        VerticalOptions="Center">

        <Label
            Text="Popup Example"
            FontSize="24"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            TextColor="#1976D2" />

        <Label
            Text="Type something below and click the button to see it in a popup."
            FontSize="15"
            TextColor="#555555"
            HorizontalOptions="Center" />

        <Entry
            x:Name="PopupEntry"
            Placeholder="Enter text for popup"
            BackgroundColor="#F5F5F5"
            TextColor="#212121"
            FontSize="16"
            HeightRequest="50" />

        <Button
            x:Name="PopupButton"
            Text="Show Popup"
            Clicked="OnPopupButtonClicked"
            BackgroundColor="#1976D2"
            TextColor="White"
            FontSize="16"
            FontAttributes="Bold"
            CornerRadius="8"
            HeightRequest="50" />

    </VerticalStackLayout>
</ContentPage>
